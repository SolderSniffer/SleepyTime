/*
 * SleepyTime — hardware overlay for prototype (discrete modules)
 *
 * Extends the upstream XIAO nRF54L15 board DTS with SleepyTime-specific
 * peripherals.
 *
 * I2C bus: i2c22 (PERI domain, P1 pins)
 *   SDA — P1.10 (XIAO D4)
 *   SCL — P1.11 (XIAO D5)
 *   pinctrl labels i2c22_default / i2c22_sleep are defined in the upstream
 *   board file xiao_nrf54l15-pinctrl.dtsi; no need to redeclare them here.
 *
 * Confirmed details:
 *   I2C address : 0x19 (SA0 high, confirmed via i2c_scan)
 *   INT1 pin    : TODO confirm against prototype wiring diagram.
 */

#include <zephyr/dt-bindings/sensor/lis2dh.h>

&i2c22 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>;

    lis3dh: lis3dh@19 {
        compatible = "st,lis2dh";
        reg = <0x19>;
        status = "okay";

        /*
         * INT1 GPIO. The lis2dh driver owns this pin — do not also
         * define it in a gpio-keys or aliases node.
         * TODO: confirm pin against prototype wiring diagram.
         */
        irq-gpios = <&gpio1 10 GPIO_ACTIVE_HIGH>;

        /*
         * Level-sensitive active-high — required for nRF54L15 GPIO sense
         * wakeup from System Off. The INT1 line must stay asserted after
         * the gesture so the sense latch fires before deep sleep completes.
         */
        int1-gpio-config = <LIS2DH_DT_GPIO_INT_LEVEL_HIGH>;

        /*
         * Fire on any axis exceeding threshold (OR combination).
         * Appropriate for wrist-raise detection regardless of watch
         * orientation on the wrist.
         */
        anym-mode = <LIS2DH_DT_ANYM_OR_COMBINATION>;
    };
};

&gpio1 {
    status = "okay";
};

&cpuapp_sram {
	#address-cells = <1>;
	#size-cells = <1>;

	retained_mem: retained@2ff00 {
		compatible = "zephyr,retained-ram";
		reg = <0x2ff00 0x100>;
		status = "okay";
		#address-cells = <1>;
		#size-cells = <1>;
	};
};

/ {
	chosen {
		zephyr,display = &ssd16xx_1in54_epaper_gdeh0154d67;
	};

	mipi_dbi_1in54_epaper_gdeh0154d67 {
		compatible = "zephyr,mipi-dbi-spi";
		spi-dev = <&xiao_spi>;
		dc-gpios = <&xiao_d 0 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&xiao_d 1 GPIO_ACTIVE_LOW>;	
		#address-cells = <1>;
		#size-cells = <0>;

		ssd16xx_1in54_epaper_gdeh0154d67: ssd16xxfb@0 {
			compatible = "gooddisplay,gdeh0154d67", "solomon,ssd1681";
			mipi-max-frequency = <4000000>;
			reg = <0>;
			width = <200>; 
			height = <200>;
			busy-gpios = <&xiao_d 3 GPIO_ACTIVE_HIGH>;

			tssv = <0x80>;

			full {
				border-waveform = <0x05>;
			};

			partial {
				border-waveform = <0x3c>;
			};
		};
	};
};

&xiao_spi {
    status = "okay";
	cs-gpios = <&xiao_d 2 GPIO_ACTIVE_LOW>;
};

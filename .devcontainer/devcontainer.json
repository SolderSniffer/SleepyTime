//
// .devcontainer/devcontainer.json
//
// VS Code Dev Containers configuration for SleepyTime.
//
// Prerequisites (one-time, host machine):
//   - Docker Desktop (macOS / Windows) or Docker Engine (Linux)
//   - VS Code extension: "Dev Containers" (ms-vscode-remote.remote-containers)
//   - Windows users: WSL 2 backend must be enabled in Docker Desktop settings
//
// Usage:
//   Open the repo in VS Code, then:
//     Ctrl+Shift+P → "Dev Containers: Reopen in Container"
//   VS Code will pull the pinned image and reopen the workspace inside it.
//   All extensions, settings, and build tasks defined here are applied
//   automatically — no manual toolchain setup required.
//
// Keeping the image in sync:
//   The `image` field below is pinned by SHA256 digest (not by tag) so that
//   every developer and CI runner is using identical bytes. When the Dockerfile
//   changes and a new image is published, update the digest here. The devenv
//   CI workflow opens a PR to do this automatically.
//
{
  "name": "SleepyTime Dev Environment",

  // ── Image ──────────────────────────────────────────────────────────────────
  // Pinned by digest, not by tag. Update this together with ci.yml when the
  // devenv image is rebuilt. Format: ghcr.io/<owner>/sleepytime-devenv@sha256:<digest>
  //
  // To find the digest after pushing:
  //   docker inspect ghcr.io/<owner>/sleepytime-devenv:latest --format '{{index .RepoDigests 0}}'
  "image": "sleepytime-devenv:local",

  // ── Container lifecycle ────────────────────────────────────────────────────
  // Mount the repo root into /workspace (matches WORKDIR in the Dockerfile).
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  // Mount a named Docker volume for ccache so incremental builds are fast across
  // container restarts. A named volume (rather than a host bind mount) is used
  // because Docker creates it automatically — no pre-existing host directory needed.
  // The volume persists across container rebuilds as long as you don't docker volume rm it.
  "mounts": [
    "source=sleepytime-ccache,target=/root/.ccache,type=volume"
  ],

  // Run as root inside the container (standard for embedded dev containers;
  // flashing tools and udev rules typically require it).
  "remoteUser": "root",

  // ── USB passthrough for flashing hardware ─────────────────────────────────
  // --privileged gives the container access to the host USB bus so that
  // OpenOCD can reach the XIAO's CMSIS-DAP debugger for `make flash`.
  // --volume=/dev/bus/usb mounts the host USB device tree into the container.
  //
  // Note: --privileged is a broad permission grant appropriate for a local
  // developer machine. Do not use this in a CI runner that builds untrusted
  // code. CI flash jobs should run on a self-hosted runner with device-specific
  // udev rules instead.
  "runArgs": [
    "--privileged",
    "--volume=/dev/bus/usb:/dev/bus/usb"
  ],

  // ── VS Code extensions (installed automatically inside the container) ──────
  "customizations": {
    "vscode": {
      "extensions": [
        // C/C++ language support + IntelliSense
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        // CMake integration (configure, build, and debug from the status bar)
        "ms-vscode.cmake-tools",
        // Cortex-M debugging via J-Link / OpenOCD
        "marus25.cortex-debug",
        // Zephyr / Kconfig editor with syntax highlighting and autocomplete
        "nordic-semiconductor.nrf-kconfig",
        // Device Tree source file support
        "nordic-semiconductor.nrf-devicetree",
        // YAML (west.yml, devcontainer.json, GitHub Actions workflows)
        "redhat.vscode-yaml",
        // Makefile task runner integration
        "ms-vscode.makefile-tools",
        // Git history and diff helpers
        "eamodio.gitlens"
      ],
      "settings": {
        // ── C/C++ IntelliSense ──────────────────────────────────────────────
        // Point the C++ extension at the compile_commands.json generated by west.
        // The build system writes this to build/debug/ by the `make build-debug` target.
        "C_Cpp.default.compileCommands": "${workspaceFolder}/build/debug/app/compile_commands.json",
        "C_Cpp.default.intelliSenseMode": "gcc-arm",
        "C_Cpp.default.cStandard": "c11",
        // ── CMake ───────────────────────────────────────────────────────────
        // Disable the CMake extension's own configure-on-open; west drives cmake.
        "cmake.configureOnOpen": false,
        "makefile.configureOnOpen": false,
        "git.openRepositoryInParentFolders": "never",
        // ── Editor ──────────────────────────────────────────────────────────
        // Enforce the project's clang-format style on save.
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "[c]": {
          "editor.defaultFormatter": "ms-vscode.cpptools"
        },
        // ── Terminal ────────────────────────────────────────────────────────
        "terminal.integrated.defaultProfile.linux": "bash",
        // ── Cortex-Debug defaults ───────────────────────────────────────────
        "cortex-debug.openocdPath": "/opt/zephyr-sdk/sysroots/x86_64-pokysdk-linux/usr/bin/openocd"
      }
    }
  },

  // ── Post-create hook ───────────────────────────────────────────────────────
  // Runs once after the container is created and the workspace is mounted.
  // Verify the toolchain is reachable and print a summary — serves as a
  // built-in smoke test that the image and mount are both working correctly.
  "postCreateCommand": "echo '--- Toolchain smoke test ---' && arm-zephyr-eabi-gcc --version && west --version && clang-format --version && echo '--- All tools OK. Run: make help ---'",

  // ── Post-start hook ────────────────────────────────────────────────────────
  // Runs on every subsequent container start.
  "postStartCommand": "ccache --show-stats"
}